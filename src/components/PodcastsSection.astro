---
import type { Lang, PodcastItem } from "../data/siteContent";
import SectionShell from "./SectionShell.astro";

interface Props {
    lang: Lang;
    title: string;
    subtitle: string;
    durationLabel: string;
    items: PodcastItem[];
}

const { lang, title, subtitle, durationLabel, items } = Astro.props;
const t = <T extends Record<Lang, string>>(entry: T) => entry[lang];
---

<SectionShell id="podcasts" title={title} subtitle={subtitle}>
    <div class="mt-6 grid gap-4 lg:grid-cols-2">
        {
            items.map((podcast) => (
                <article class="rounded-2xl border border-fuchsia-400/25 bg-white/65 shadow-[0_18px_36px_rgba(124,58,237,0.14)] backdrop-blur-md transition-all duration-300 hover:-translate-y-0.5 hover:border-fuchsia-400/35 hover:bg-white/75 dark:border-fuchsia-300/20 dark:bg-violet-950/65 dark:shadow-[0_20px_42px_rgba(3,2,9,0.58)] dark:hover:bg-violet-900/75">
                    <div class="space-y-2 p-4">
                        <h3 class="text-lg font-semibold">
                            {t(podcast.title)}
                        </h3>
                        <p class="text-zinc-600 dark:text-violet-300">
                            {t(podcast.description)}
                        </p>
                        <p class="text-sm text-zinc-600 dark:text-violet-400">
                            <strong>{durationLabel}:</strong> {podcast.length}
                        </p>
                    </div>
                </article>
            ))
        }
    </div>
</SectionShell>
