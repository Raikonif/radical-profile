---
import { supabaseServer } from "@/lib/supabase/server";
import BaseLayout from "@/layouts/BaseLayout.astro";

export const prerender = true;

const lang = "es";

type CaseRow = {
    id: number;
    cases_translations:
        | {
              title: string | null;
              language: string | null;
          }[]
        | null;
};

const { data, error } = await supabaseServer
    .from("cases")
    .select("id, cases_translations!inner(title, language, is_active)")
    .eq("cases_translations.language", lang)
    .eq("cases_translations.is_active", true)
    .limit(20)
    .returns<CaseRow[]>();

const rows: CaseRow[] = data ?? [];
---

<BaseLayout
    lang="en"
    title="Supabase Test (Static)"
    description="Build-time Supabase query from Astro prerender."
    footerText="Supabase static test page"
>
    {error ? <p>Query error: {error.message}</p> : null}

    <ul>
        {
            rows.map((entry) => (
                <li>
                    {entry.cases_translations?.[0]?.title ?? "Untitled case"}
                </li>
            ))
        }
    </ul>
</BaseLayout>
