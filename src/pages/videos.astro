---
import SiteHeader from "@/components/SiteHeader.astro";
import { getVideosContent } from "@/lib/content";
import { uiText, type Lang } from "@/data/siteContent";
import BaseLayout from "@/layouts/BaseLayout.astro";

export const prerender = import.meta.env.CONTENT_RENDER_MODE === "ssg";

const queryLang = Astro.url.searchParams.get("lang");
const cookieLang = Astro.cookies.get("lang")?.value;
const selectedLang = (
  queryLang === "es" || queryLang === "en" ? queryLang : cookieLang
) as Lang | undefined;
const lang: Lang = selectedLang ?? "es";

Astro.cookies.set("lang", lang, {
  path: "/",
  httpOnly: false,
  sameSite: "lax",
  maxAge: 60 * 60 * 24 * 365,
});

const t = <T extends Record<Lang, string>>(entry: T) => entry[lang];
const currentPath = Astro.url.pathname;
const currentSearch = Astro.url.search;

const sectionLabels = {
  inicio: t(uiText.sections.inicio),
  casos: t(uiText.sections.casos),
  esquemas: t(uiText.sections.esquemas),
  divulgacion: t(uiText.sections.divulgacion),
  podcasts: t(uiText.sections.podcasts),
  videos: t(uiText.sections.videos),
  contacto: t(uiText.sections.contacto),
};

const pageText = {
  studioLabel: { es: "Laboratorio de video", en: "Video lab" },
  heroTitle: {
    es: "Videos desde Supabase con RLS en SSR.",
    en: "Supabase videos with RLS on SSR.",
  },
  heroBody: {
    es: "Esta vista consulta `videos` y `videos_translations` por idioma y estado activo.",
    en: "This view queries `videos` and `videos_translations` by language and active state.",
  },
  videosCount: { es: "Videos", en: "Videos" },
  fallbackNotice: {
    es: "Sin resultados en este idioma. Mostrando contenido alternativo.",
    en: "No results in this language. Showing fallback content.",
  },
  emptyState: {
    es: "No hay videos visibles con la configuracion actual de RLS.",
    en: "No videos are visible with the current RLS configuration.",
  },
  openFile: { es: "Abrir video", en: "Open video" },
  goPodcasts: { es: "Ir a podcasts", en: "Go to podcasts" },
  backHome: { es: "Volver al homepage", en: "Back to homepage" },
};

let videoItems = [];
let sourceLang: Lang = lang;
let queryError = "";

try {
  const response = await getVideosContent(lang, 20);
  videoItems = response.items;
  sourceLang = response.sourceLang;
} catch (error) {
  queryError = error instanceof Error ? error.message : "Unknown error";
}
---

<BaseLayout
  lang={lang}
  title={`${t(uiText.sections.videos)} | ${t(uiText.siteTitle)}`}
  description={t(uiText.videoSubtitle)}
  footerText={t(uiText.footer)}
>
  <SiteHeader
    lang={lang}
    siteTitle={t(uiText.siteTitle)}
    homeHref={`/?lang=${lang}`}
    currentPath={currentPath}
    currentSearch={currentSearch}
    sections={sectionLabels}
    languageLabel={t(uiText.languageLabel)}
    themeLabel={t(uiText.themeLabel)}
    lightLabel={t(uiText.lightLabel)}
    darkLabel={t(uiText.darkLabel)}
  />

  <main class="mx-auto w-[min(1120px,92vw)] py-8">
    <section
      id="inicio"
      class="rounded-3xl border border-violet-400/30 bg-[linear-gradient(130deg,rgba(255,255,255,0.75),rgba(244,232,255,0.7),rgba(238,242,255,0.72))] p-7 shadow-[0_24px_60px_rgba(99,102,241,0.2)] backdrop-blur-xl dark:border-violet-300/20 dark:bg-[linear-gradient(130deg,rgba(24,18,38,0.88),rgba(34,20,54,0.85),rgba(22,20,40,0.9))]"
    >
      <p class="text-xs uppercase tracking-[0.16em] text-indigo-600 dark:text-indigo-300">{t(pageText.studioLabel)}</p>
      <h1 class="mt-3 max-w-3xl text-3xl font-extrabold text-zinc-900 dark:text-zinc-100 md:text-5xl">{t(pageText.heroTitle)}</h1>
      <p class="mt-4 max-w-2xl text-sm text-zinc-700 dark:text-zinc-300">{t(pageText.heroBody)}</p>
    </section>

    <section id="casos" class="mt-8 grid gap-4 md:grid-cols-3">
      <article class="rounded-2xl border border-fuchsia-400/25 bg-white/55 p-5 backdrop-blur-md dark:border-fuchsia-300/20 dark:bg-[#1a1529]/65">
        <p class="text-xs uppercase tracking-[0.11em] text-zinc-500 dark:text-zinc-400">{t(pageText.videosCount)}</p>
        <p class="mt-2 text-3xl font-bold text-zinc-900 dark:text-zinc-100">{String(videoItems.length).padStart(2, "0")}</p>
      </article>
    </section>

    {queryError ? (
      <section class="mt-6 rounded-xl border border-rose-400/30 bg-rose-500/10 p-4 text-sm text-rose-700 dark:text-rose-200">
        Supabase error: {queryError}
      </section>
    ) : null}

    {!queryError && sourceLang !== lang && videoItems.length > 0 ? (
      <section class="mt-6 rounded-xl border border-amber-400/30 bg-amber-500/10 p-4 text-sm text-amber-700 dark:text-amber-200">
        {t(pageText.fallbackNotice)}
      </section>
    ) : null}

    <section id="esquemas" class="mt-8 grid gap-5 lg:grid-cols-2">
      {videoItems.map((video, idx) => (
        <article class="overflow-hidden rounded-2xl border border-zinc-200/70 bg-white/70 shadow-[0_16px_36px_rgba(79,70,229,0.18)] backdrop-blur-md dark:border-violet-300/15 dark:bg-[#19142a]/70">
          <div class="p-5">
            <p class="text-xs uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-400">Clip {String(idx + 1).padStart(2, "0")}</p>
            <h2 class="mt-2 text-xl font-semibold text-zinc-900 dark:text-zinc-100">{video.name}</h2>
            <p class="mt-2 text-sm text-zinc-700 dark:text-zinc-300">{video.description}</p>
            {video.fileUrl ? (
              <a
                href={video.fileUrl}
                target="_blank"
                rel="noreferrer"
                class="mt-4 inline-flex rounded-md border border-indigo-400/30 bg-indigo-500/10 px-3 py-1.5 text-xs font-medium text-indigo-700 dark:text-indigo-200"
              >
                {t(pageText.openFile)}
              </a>
            ) : null}
          </div>
        </article>
      ))}
    </section>

    {videoItems.length === 0 && !queryError ? (
      <p class="mt-4 text-sm text-zinc-600 dark:text-zinc-300">{t(pageText.emptyState)}</p>
    ) : null}

    <section id="videos" class="mt-8 grid gap-4 md:grid-cols-2">
      <a
        href={`/podcasts?lang=${lang}`}
        class="rounded-2xl border border-zinc-200 bg-white/65 p-5 text-sm text-zinc-700 transition hover:border-violet-400/40 hover:text-zinc-900 dark:border-violet-300/20 dark:bg-[#1a1429]/65 dark:text-zinc-200"
      >
        {t(pageText.goPodcasts)}
      </a>
      <a
        href={`/?lang=${lang}`}
        class="rounded-2xl border border-zinc-200 bg-white/65 p-5 text-sm text-zinc-700 transition hover:border-violet-400/40 hover:text-zinc-900 dark:border-violet-300/20 dark:bg-[#1a1429]/65 dark:text-zinc-200"
      >
        {t(pageText.backHome)}
      </a>
    </section>
  </main>
</BaseLayout>
